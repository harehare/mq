{
  "name": "mq-nodejs",
  "description": "A jq-like command-line tool for Markdown processing for Node.js",
  "version": "0.6.5",
  "author": "harehare",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/harehare/mq/issues"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "esbuild": "^0.28.1",
    "oxlint": "^1.74.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://mqlang.org",
  "keywords": [
    "filter",
    "jq",
    "markdown",
    "transform",
    "wasm",
    "webassembly",
    "nodejs"
  ],
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harehare/mq.git",
    "directory": "packages/mq-nodejs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && rm dist/.gitignore",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.33.0",
  "sideEffects": false,
  "types": "dist/index.d.ts"
}
